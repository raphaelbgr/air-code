{
  "name": "air-code",
  "version": "0.1.0",
  "description": "Web-based canvas for managing multiple AI coding agent terminal sessions with real-time streaming, workspace organization, and session forking",
  "author": "Raphael Bernardo <raphaelbgr@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raphaelbgr/air-code.git"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "terminal",
    "session-manager",
    "canvas",
    "xterm",
    "websocket",
    "tmux",
    "developer-tools",
    "react"
  ],
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n sms,was -c blue,green \"pnpm --filter @air-code/sms dev\" \"pnpm --filter @air-code/was dev\"",
    "dev:sms": "pnpm --filter @air-code/sms dev",
    "dev:was": "pnpm --filter @air-code/was dev",
    "dev:web": "pnpm --filter @air-code/web dev",
    "kill-all": "python scripts/kill-all.py",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
